STRIPE_SECRET_KEY=your-stripe-secret-key
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=your-stripe-publishable-key
# Optional: required for live inventory decrement after paid checkouts.
# Stripe Dashboard → Developers → Webhooks → endpoint /api/webhooks/stripe
# Events: checkout.session.completed
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret
NEXT_PUBLIC_BASE_URL=http://localhost:3001
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
ADMIN_DASHBOARD_PASSWORD=choose-a-strong-admin-password
# Optional: separate HMAC secret for admin session cookies (recommended in prod).
ADMIN_SESSION_SECRET=choose-a-long-random-session-secret

# Optional durable rate limiting (Upstash Redis REST). Highly recommended on Vercel.
# Without these, limits fall back to in-memory per serverless instance.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Optional Amazon SP-API read-only connector settings.
# Leave blank until the Seller Central/SP-API app is authorized.
AMAZON_SELLER_ID=
AMAZON_MARKETPLACE_ID=
AMAZON_LWA_CLIENT_ID=
AMAZON_LWA_CLIENT_SECRET=
AMAZON_REFRESH_TOKEN=
AMAZON_REGION=

# Optional TikTok Shop read-only connector settings.
# Leave blank until the TikTok Shop app is authorized by the seller account.
TIKTOK_SHOP_APP_KEY=
TIKTOK_SHOP_APP_SECRET=
TIKTOK_SHOP_ACCESS_TOKEN=
TIKTOK_SHOP_REFRESH_TOKEN=
TIKTOK_SHOP_ID=
TIKTOK_SHOP_REGION=

# Production example: NEXT_PUBLIC_BASE_URL=https://forgegym.us
